// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "VimControl && !menu",
    "bindings": {
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "space": null,
      "tab": null,
    },
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      "tab": "editor::ConfirmCompletion",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-a t t": [
        "task::Spawn",
        { "task_name": "Test: Create colocated test file" },
      ],
    },
  },
  {
    "bindings": {
      // Navigation
      "cmd-e": "project_panel::ToggleFocus",
      "cmd-g": "git_panel::ToggleFocus",
      "cmd-o": "projects::OpenRecent",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",

      // Finders
      "ctrl-a s f": "file_finder::Toggle",
      "ctrl-a s s": "project_symbols::Toggle",
      "ctrl-a s t": "tab_switcher::ToggleAll",

      // Git
      "ctrl-a g p": "git::Pull",
      "ctrl-a g P": "git::Push",
      "ctrl-a g b": "git::Branch",
      "ctrl-a g s s": "git::StashAll",
      "ctrl-a g s p": "git::StashPop",
      "ctrl-a g g": [
        "task::Spawn",
        { "task_name": "LazyGit", "reveal_target": "center" },
      ],
    },
  },
]
