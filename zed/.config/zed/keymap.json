// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "VimControl && !menu",
    "bindings": {
      "j": ["vim::Down", { "display_lines": true }],
      "k": ["vim::Up", { "display_lines": true }],
      "space f f": "editor::Format",

      // Finders
      "space s f": "file_finder::Toggle",
      "space s c": "text_finder::Toggle",
      "space s s": "project_symbols::Toggle",
      "space s t": "tab_switcher::ToggleAll",

      // Navigation
      "shift-n": "vim::ChangeListNewer",
      "shift-p": "vim::ChangeListOlder",
      "[ [": "editor::MoveToStartOfLargerSyntaxNode",
      "] ]": "editor::MoveToEndOfLargerSyntaxNode",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::HelixJumpToWord",
    },
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "space": null,
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "enter": "editor::Newline",
    },
  },
  {
    "bindings": {
      // Git
      "cmd-g p": "git::Pull",
      "cmd-g P": "git::Push",
      "cmd-g b": "git::Branch",
      "cmd-g w": "git::Worktree",
      "cmd-g c": "git_panel::Toggle",
      "cmd-g g": [
        "task::Spawn",
        { "task_name": "LazyGit", "reveal_target": "center" },
      ],

      // Navigation
      "cmd-e": "project_panel::ToggleFocus",
      "cmd-o": "projects::OpenRecent",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
]
