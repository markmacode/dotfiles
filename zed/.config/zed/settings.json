{
  // Zed settings
  //
  // For information on how to configure Zed, see the Zed//zed.dev/docs/configuring-zed
  //
  // To see all of Zed's default settings without changing your
  // custom settings, run `zed: open default settings` from the
  // command palette (cmd-shift-p / ctrl-shift-p)
  "diff_view_style": "split",
  "buffer_font_size": 15.0,
  "buffer_font_family": "Brosevka Nerd Font",
  "buffer_font_weight": 400,
  "terminal": {
    "font_weight": 400,
  },
  "format_on_save": "off",
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "excerpt_context_lines": 3,
  "wrap_guides": [88],
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "completions": {
    "lsp_insert_mode": "insert",
  },
  "show_completions_on_input": true,
  "snippet_sort_order": "bottom",
  "edit_predictions": {
    "mode": "subtle",
  },
  "project_panel": {
    "git_status_indicator": true,
    "auto_fold_dirs": true,
    "indent_size": 20.0,
    "entry_spacing": "standard",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "vertical_scroll_margin": 8.0,
  "relative_line_numbers": "enabled",
  "autosave": {
    "after_delay": {
      "milliseconds": 500,
    },
  },
  "buffer_line_height": {
    "custom": 1.3,
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "theme_overrides": {
    "One Light": {
      "syntax": {
        "comment": {
          "font_style": "italic",
          "font_weight": 300,
        },
        "function.definition": {
          "color": "#5B79E3",
          "font_weight": 700,
        },
        "function.kwargs": {
          "color": "#a39858",
          "font_style": "italic",
        },
        "type.class.definition": {
          "color": "#3882B7",
          "font_weight": 700,
        },
        "string.doc": {
          "color": "#A2A3A7",
          "font_weight": 300,
        },
      },
    },
    "Dracula Light (Alucard)": {
      "vim.helix_jump_label.foreground": "#e60058",
      "syntax": {
        "function.definition": {
          "color": "#14710A",
          "font_weight": 700,
        },
        "function.kwargs": {
          "color": "#504254",
          "font_style": "italic",
        },
        "type.class.definition": {
          "color": "#036A96",
          "font_weight": 700,
        },
      },
    },
  },
  "vim_mode": true,
  "which_key": {
    "enabled": true,
  },
  "languages": {
    "Python": {
      "language_servers": ["ty", "ruff"],
      "code_actions_on_format": {
        "source.organizeImports": true,
        "source.fixAll.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
    "HTML": {
      "formatter": "language_server",
    },
  },
  "lsp": {},
  "file_types": {
    "Dockerfile": ["Dockerfile*", "dockerfile*"],
    "Shell Script": [".envrc"],
  },
  "profiles": {
    "Focus": {
      "settings": {
        "ui_font_size": 18,
        "buffer_font_size": 20,
      },
    },
  },
}
