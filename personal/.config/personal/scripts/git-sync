#!/usr/bin/env bash

set -euo pipefail

if [[ "$#" -lt 1 ]]; then
  echo "Usage: git sync <version>"
  exit 1
fi

VERSION=$1
RELEASE_REF="origin/release/${VERSION}.x"
BRANCH_NAME="chore/CURE-0/sync-release-${VERSION}.x"

git fetch

# Ignore pipe errors if pager quits early
git log --oneline --graph "origin/main...${RELEASE_REF}" || true

read -r -p "Continue? (y/n): " choice
if [[ "$choice" != "y" && "$choice" != "Y" ]]; then
  echo "Aborted."
  exit 0
fi

git checkout --no-track -b "${BRANCH_NAME}" origin/main
git rebase -i "${RELEASE_REF}"
gh pr create --title "chore: sync release/${VERSION}.x" --base main --web
